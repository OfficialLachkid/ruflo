{
  "schema_version": "1.0.0",
  "run_at": "2026-07-20T00:00:00.000Z",
  "output_directory": "data/runtime/product-video-agent",
  "content_strategy": {
    "primary": "short_form",
    "platforms": [
      "youtube_shorts",
      "instagram_reels",
      "tiktok"
    ],
    "long_form": {
      "enabled": false,
      "target_duration_minutes": {
        "min": 2,
        "max": 5
      }
    }
  },
  "script": {
    "provider": "ollama",
    "model": "llama3.1:8b",
    "endpoint": "http://127.0.0.1:11434",
    "prompt_version": "short-form-v1",
    "keep_alive": "0s",
    "variants": [
      {
        "angle": "problem_solution",
        "target_duration_seconds": 35
      },
      {
        "angle": "demonstration",
        "target_duration_seconds": 45
      },
      {
        "angle": "novelty",
        "target_duration_seconds": 30
      }
    ]
  },
  "voice": {
    "provider": "piper",
    "executable": ".venv-product-video/bin/python",
    "data_directory": "data/runtime/product-video-agent/models/piper",
    "assignment_strategy": "round_robin",
    "default_profile_id": "us-female-ljspeech",
    "profiles": [
      {
        "profile_id": "us-female-ljspeech",
        "model": "en_US-ljspeech-high",
        "voice": "en_US-ljspeech-high",
        "language": "en-US",
        "license_record_path": "services/product-video-agent/voices/en_US-ljspeech-high.license.json",
        "synthesis": {
          "length_scale": 0.97
        }
      },
      {
        "profile_id": "us-male-norman",
        "model": "en_US-norman-medium",
        "voice": "en_US-norman-medium",
        "language": "en-US",
        "license_record_path": "services/product-video-agent/voices/en_US-norman-medium.license.json",
        "synthesis": {
          "length_scale": 0.96
        }
      }
    ]
  },
  "captions": {
    "provider": "faster_whisper",
    "executable": ".venv-product-video/bin/python",
    "script_path": "services/transcription-worker/local-transcribe.py",
    "model": "small.en",
    "max_words_per_line": 4
  },
  "render": {
    "renderer": "ffmpeg",
    "executable": "auto",
    "purpose": "publication_candidate",
    "template_id": "vertical-product-v1",
    "template_path": "services/product-video-agent/vertical-product-v1.template.json",
    "fps": 30
  },
  "affiliate_disclosure": "This content contains affiliate links. We may earn a commission at no extra cost to you.",
  "operator": "orion-operator"
}
