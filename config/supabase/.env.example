# Local-only Supabase runtime config.
# Copy to config/supabase/.env on the Mac mini.
# Do not commit real values.

# Project URL from Supabase -> Settings -> API
SUPABASE_URL=

# Backend-only secret key from Supabase -> Settings -> API Keys
# Never expose this in frontend code, Discord, the vault, or git.
SUPABASE_SECRET_KEY=

# Optional for future client-side or server-side typed integrations.
# Keep local-only for now until frontend exposure is explicitly approved.
SUPABASE_PUBLISHABLE_KEY=

# Optional metadata for later tooling.
SUPABASE_PROJECT_REF=

# Optional device label for memory sync records and sync-run audit rows.
ORION_SOURCE_DEVICE=
