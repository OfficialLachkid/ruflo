    "variants": [
      {
        "angle": "problem_solution",
        "target_duration_seconds": 35
      },
      {
        "angle": "demonstration",
        "target_duration_seconds": 45
      },
      {
        "angle": "novelty",
        "target_duration_seconds": 30
      }
    ]
  },
  "voice": {
    "provider": "piper",
    "executable": ".venv-product-video/bin/python",
    "model": "en_US-lessac-medium",
    "data_directory": "data/runtime/product-video-agent/models/piper",
    "voice": "en_US-lessac-medium",
    "language": "en-US"
  },
  "render": {
    "renderer": "ffmpeg",
    "template_id": "vertical-product-v1",
    "fps": 30
  },
  "affiliate_disclosure": "This content contains affiliate links. We may earn a commission at no extra cost to you.",
  "operator": "orion-operator"
}
