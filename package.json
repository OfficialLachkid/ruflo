{
  "name": "claude-flow",
  "version": "3.7.0-alpha.71",
  "description": "Ruflo - Enterprise AI agent orchestration for Claude Code. Deploy 60+ specialized agents in coordinated swarms with self-learning, fault-tolerant consensus, vector memory, and MCP integration",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "claude-flow": "./bin/cli.js"
  },
  "homepage": "https://github.com/ruvnet/claude-flow#readme",
  "bugs": {
    "url": "https://github.com/ruvnet/claude-flow/issues",
    "email": "support@ruv.io"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/ruvnet"
  },
  "files": [
    "bin/**",
    "v3/@claude-flow/cli/bin/**",
    "v3/@claude-flow/cli/dist/**/*.js",
    "v3/@claude-flow/cli/dist/**/*.d.ts",
    "!v3/@claude-flow/cli/dist/**/*.map",
    "v3/@claude-flow/cli/package.json",
    "v3/@claude-flow/shared/dist/**/*.js",
    "v3/@claude-flow/shared/dist/**/*.d.ts",
    "!v3/@claude-flow/shared/dist/**/*.map",
    "v3/@claude-flow/shared/package.json",
    "v3/@claude-flow/guidance/dist/**/*.js",
    "v3/@claude-flow/guidance/dist/**/*.d.ts",
    "!v3/@claude-flow/guidance/dist/**/*.map",
    "v3/@claude-flow/guidance/package.json",
    ".claude-plugin/**",
    ".claude/**",
    "!.claude/**/*.db",
    "!.claude/**/*.map",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:ts": "cd v3/@claude-flow/cli && npm run build || true",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:security": "vitest run v3/__tests__/security/",
    "lint": "cd v3/@claude-flow/cli && npm run lint || true",
    "security:audit": "npm audit --audit-level high",
    "security:fix": "npm audit fix",
    "security:test": "npm run test:security",
    "v3:domains": "npm run build:domains",
    "v3:swarm": "npm run start:swarm",
    "v3:security": "npm run security:audit && npm run security:test",
    "session:start": "node scripts/session-start.mjs",
    "session:checkpoint": "node scripts/session-checkpoint.mjs",
    "session:pre-limit-checkpoint": "node scripts/session-pre-limit-checkpoint.mjs",
    "session:end": "node scripts/session-end.mjs",
    "session:restore": "node scripts/session-restore.mjs",
    "vault:sync": "node scripts/sync-vault.mjs",
    "memory:verify-promotion-rules": "node scripts/verify-memory-promotion-rules.mjs",
    "memory:sync-promotion-rules-playbook": "node scripts/sync-promotion-rules-playbook.mjs",
    "discord:restart": "node scripts/discord-bot-restart.mjs",
    "gmail:authorize": "node scripts/gmail-authorize.mjs",
    "gmail:send-test": "node scripts/gmail-send-test.mjs",
    "ruflo:install-daemon-launch-agent": "node scripts/install-ruflo-daemon-launch-agent.mjs",
    "discord:simulate": "node services/discord-bot/index.mjs",
    "discord:live": "node services/discord-bot/index.mjs --live",
    "discord:register-commands": "node scripts/register-discord-commands.mjs",
    "discord:daily-summary": "node services/discord-bot/index.mjs --daily-summary",
    "discord:health-monitor": "node services/discord-bot/index.mjs --health-monitor",
    "discord:install-live-launch-agent": "node scripts/install-discord-live-launch-agent.mjs",
    "discord:install-daily-summary-schedule": "node scripts/install-daily-summary-schedule.mjs",
    "discord:install-health-monitor-schedule": "node scripts/install-health-monitor-schedule.mjs",
    "claude:run-task": "node services/claude-runner/index.mjs",
    "claude:doctor": "node scripts/claude-runner-doctor.mjs",
    "claude:canary": "node scripts/claude-runner-canary.mjs",
    "claude:resume": "node scripts/claude-runner-resume.mjs",
    "claude:install-resume-watch-schedule": "node scripts/install-claude-resume-watch-schedule.mjs",
    "mac:reboot-recovery-check": "node scripts/mac-reboot-recovery-check.mjs",
    "website-builder:dev": "node scripts/website-builder-dev-server.mjs",
    "runtime:mac-sync": "node scripts/mac-sync-worker.mjs",
    "runtime:mac-sync-watch": "node scripts/mac-sync-watch.mjs",
    "runtime:install-mac-sync-watch-schedule": "node scripts/install-mac-sync-watch-schedule.mjs",
    "runtime:install-mac-sync-watch-schedule:test": "node scripts/install-mac-sync-watch-schedule.mjs --interval-seconds 60",
    "runtime:install-mac-sync-watch-schedule:daytime": "node scripts/install-mac-sync-watch-schedule.mjs --hours 6,10,14,18,22 --minute 0",
    "runtime:install-mac-sync-watch-schedule:daily": "node scripts/install-mac-sync-watch-schedule.mjs --hours 6 --minute 0",
    "supabase:check": "node scripts/check-supabase-connection.mjs",
    "supabase:merge-bridge": "node scripts/supabase-merge-bridge.mjs",
    "supabase:sync-bridge": "node scripts/supabase-sync-bridge.mjs",
    "task-router:simulate": "node services/task-router/index.mjs",
    "transcription:simulate": "node services/transcription-worker/index.mjs",
    "test:discord-spine": "node --test services/task-router/test/router.test.mjs services/task-router/test/executor.test.mjs services/task-router/test/claude-delegate.test.mjs services/task-router/test/ops-tool-run.test.mjs services/developer-agent/test/command-parser.test.mjs services/developer-agent/test/workflow.test.mjs services/claude-runner/test/runner.test.mjs services/discord-bot/test/intake.test.mjs services/discord-bot/test/acknowledgement.test.mjs services/discord-bot/test/live-runtime.test.mjs services/discord-bot/test/message-formatting.test.mjs services/discord-bot/test/message-formatting-legacy.test.mjs services/discord-bot/test/github-ci-observer.test.mjs services/discord-bot/test/daily-summary.test.mjs services/discord-bot/test/health-monitor.test.mjs services/discord-bot/test/pending-task-store.test.mjs services/discord-bot/test/slash-commands.test.mjs services/gmail/test/config.test.mjs services/gmail/test/oauth.test.mjs services/gmail/test/mime.test.mjs services/gmail/test/send.test.mjs scripts/test/ci-notification-context.test.mjs scripts/test/mac-sync-worker-utils.test.mjs scripts/test/mac-sync-watch.test.mjs scripts/test/supabase-memory-sync-utils.test.mjs scripts/test/claude-runner-diagnostics.test.mjs scripts/test/claude-runner-recovery.test.mjs scripts/test/claude-runner-doctor.test.mjs scripts/test/claude-runner-canary.test.mjs scripts/test/session-pre-limit-checkpoint.test.mjs scripts/test/memory-promotion-audit.test.mjs scripts/test/verify-memory-promotion-rules.test.mjs scripts/test/reboot-recovery-check.test.mjs scripts/test/mac-reboot-recovery-check.test.mjs scripts/test/discord-post.test.mjs scripts/test/website-builder-storage.test.mjs scripts/test/website-builder-supabase.test.mjs"
  },
