# Gmail sender configuration for O.R.I.O.N. outbound.
# Copy this file to config/gmail/.env and fill in the values.
# Never commit config/gmail/.env — it is gitignored.

# OAuth 2.0 client credentials from Google Cloud Console.
# App type must be "Desktop app" for the loopback flow used by scripts/gmail-authorize.mjs.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Loopback port used by the authorize flow. Must exactly match one of the
# authorized redirect URIs on the OAuth client (e.g. http://127.0.0.1:53682/callback).
GMAIL_OAUTH_LOOPBACK_PORT=53682

# Filled in automatically by scripts/gmail-authorize.mjs after a successful browser grant.
GMAIL_REFRESH_TOKEN=

# The exact Gmail address that will appear in the From: header.
# Must be an address the granted account can send from.
GMAIL_SENDER_EMAIL=
GMAIL_SENDER_NAME=

# Optional. Comma-separated list of BCC addresses added to every outbound send
# (for internal auditing). Leave blank for none.
GMAIL_BCC_AUDIT=

# Draft-only guard. When true, calls to gmail.send are refused and messages are
# stored as drafts only. Default: false. Flip to true for a dry-run week.
GMAIL_DRAFT_ONLY=false
