{
  "schema_version": "1.0.0",
  "run_at": "2026-07-20T00:00:00.000Z",
  "output_directory": "data/runtime/product-video-agent",
  "content_strategy": {
    "primary": "short_form",
    "platforms": [
      "youtube_shorts",
      "instagram_reels",
      "tiktok"
    ],
    "long_form": {
      "enabled": false,
      "target_duration_minutes": {
        "min": 2,
        "max": 5
      }
    }
  },
  "script": {
