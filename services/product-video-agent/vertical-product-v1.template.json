{
  "template_id": "vertical-product-v1",
  "version": "1.1.0",
  "canvas": {
    "width": 1080,
    "height": 1920,
    "fps": 30,
    "safe_zone": {
      "top": 180,
      "right": 120,
      "bottom": 300,
      "left": 120
    }
  },
  "timeline": [
    {
      "segment": "hook",
      "duration_seconds": 3,
      "caption_emphasis": "high"
    },
    {
      "segment": "demonstration",
      "duration_seconds": 22,
      "caption_emphasis": "normal"
    },
    {
      "segment": "proof_and_specs",
      "duration_seconds": 10,
      "caption_emphasis": "normal"
    },
    {
      "segment": "cta_and_disclosure",
      "duration_seconds": 5,
      "caption_emphasis": "high"
    }
  ],
  "captions": {
    "max_words_per_line": 5,
    "max_lines": 2,
    "position": "lower_middle",
    "animation": "ass_karaoke_word_highlight",
    "font_family": "Avenir Next",
    "font_size": 74,
    "outline_size": 6
  },
  "audio": {
    "voice_peak_db": -3,
    "music_target_lufs": -24,
    "duck_music_under_voice": true,
    "music_enabled": false,
    "music_blocker": "No rights-approved local music fixture is configured."
  },
  "renderer": {
    "visual_inputs": 1,
    "video_codec": "libx264",
    "pixel_format": "yuv420p",
    "audio_codec": "aac",
    "audio_bitrate": "192k",
    "crf": 20,
    "faststart": true
  }
}
